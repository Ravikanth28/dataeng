# Copy this file to ".env" and fill in real values.
# The .env file is gitignored and must NEVER be committed or pushed.

# TiDB connection (MySQL-compatible). Note the "mysql+pymysql://" prefix.
DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:4000/<database>

# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173

# Token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=10080
